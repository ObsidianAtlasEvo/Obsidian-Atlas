# =============================================================================
# Obsidian Atlas — backend (Fastify). Copy to `.env` and fill secrets.
# Load order: repo `.env.local` → repo `.env` → `atlas-backend/.env` (last wins).
# =============================================================================

PORT=3001
# Production (bind all interfaces for reverse proxy on same host)
# HOST=0.0.0.0
SQLITE_PATH=./data/atlas.db

# --- Required thresholds (evolution / datasets) ---
MEMORY_CONFIDENCE_THRESHOLD=0.72
DATASET_SCORE_THRESHOLD=0.80
EVAL_GAP_THRESHOLD=0.42
DATASET_MIN_AXIS_SCORE=9

# Background Ollama JSON (evolution, structured extractions)
EVOLUTION_LLM_TIMEOUT_MS=120000

# Sovereign local omni-stream (default 600000 = 10 min)
# OMNI_LOCAL_TIMEOUT_MS=600000

# Groq Chief routing JSON timeout (ms)
# OMNI_ROUTER_TIMEOUT_MS=12000

# -----------------------------------------------------------------------------
# LOCAL OLLAMA — all Llama (and other) tags you have installed
# -----------------------------------------------------------------------------
# Point at your Ollama API. List models: `ollama list`
OLLAMA_BASE_URL=http://localhost:11434/api

# Default chat model (must match `ollama list` exactly)
OLLAMA_CHAT_MODEL=llama3.1:8b

# Embeddings (Memory Vault / semantic paths)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: smaller model for background evolution JSON (defaults to OLLAMA_CHAT_MODEL)
# OLLAMA_EVOLUTION_MODEL=llama3.1:8b

# Optional: explicit fallback chain — comma-separated, same names as `ollama list`.
# If unset, Atlas also auto-discovers installed models via GET /api/tags.
# Example (mix of Llama sizes + alternates):
# OLLAMA_MODEL_POOL=llama3.1:70b,llama3.1:8b,llama3.2:3b,mistral:7b,qwen2.5:7b

# false = sovereign owner can use local GPU; true = force cloud swarm for everyone
DISABLE_LOCAL_OLLAMA=false

# -----------------------------------------------------------------------------
# CLOUD — Groq + Gemini (Resonance consensus, public swarm, router fail-safe)
# -----------------------------------------------------------------------------
GROQ_API_KEY=
# Optional — default https://api.groq.com/openai/v1
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Chief-of-Staff JSON planner (fast model)
# GROQ_ROUTER_MODEL=llama-3.1-8b-instant

# Registry / delegate completions when a step uses Groq
# GROQ_DELEGATE_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=
# Default Gemini id for registry streaming when not using consensus-specific ids
# GEMINI_MODEL=gemini-1.5-pro

# OpenAI-compatible fail-safe for hybrid router (optional — if unset, uses GROQ_API_KEY + Groq URL)
# ATLAS_CLOUD_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# ATLAS_CLOUD_OPENAI_API_KEY=
# ATLAS_CLOUD_CHAT_MODEL=llama-3.3-70b-versatile

# Maximum Clarity + dual-lane consensus (Groq + Gemini parallel → judge)
# You may set only GEMINI_MODEL / CONSENSUS_GROQ_MODEL — aliases are merged in code.
CONSENSUS_GEMINI_MODEL=gemini-1.5-pro
CONSENSUS_GROQ_ANALYST_MODEL=llama-3.3-70b-versatile
# Legacy alias for CONSENSUS_GROQ_ANALYST_MODEL:
# CONSENSUS_GROQ_MODEL=llama-3.3-70b-versatile
CONSENSUS_GROQ_ALT_MODEL=mixtral-8x7b-32768
CONSENSUS_GROQ_JUDGE_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# OAuth (Google) — callback must be ${NEXTAUTH_URL}/auth/google/callback
# Production example: https://obsidianatlastech.com/auth/google/callback
# Verify GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET in Google Cloud Console (same OAuth client).
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
# APP_URL= optional; set to public SPA origin in production, e.g. https://obsidianatlastech.com
# Production (tunnel / public host) — uncomment and match Google redirect URI host:
# NEXTAUTH_URL=https://obsidianatlastech.com
# AUTH_URL=https://obsidianatlastech.com
# APP_URL=https://obsidianatlastech.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_SECRET=
# AUTH_SECRET=

# -----------------------------------------------------------------------------
# Research (Maximum Clarity quota)
# -----------------------------------------------------------------------------
# SYSTEM_TAVILY_API_KEY=
# TAVILY_API_KEY=

# CORS override (comma-separated). If set, replaces defaults — include every browser origin you use.
# Defaults already include https://obsidianatlastech.com and localhost dev ports.
#
# Production (same-origin SPA at https://obsidianatlastech.com):
#   HOST=0.0.0.0
#   CORS_ORIGINS=https://obsidianatlastech.com
#   NEXTAUTH_URL=https://obsidianatlastech.com
#   AUTH_URL=https://obsidianatlastech.com
#   GOOGLE_CLIENT_ID=...  GOOGLE_CLIENT_SECRET=...  NEXTAUTH_SECRET=...
# Google redirect URI: https://obsidianatlastech.com/auth/google/callback
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://obsidianatlastech.com,https://www.obsidianatlastech.com

# -----------------------------------------------------------------------------
# REQUIRED — server will refuse to start without these
# -----------------------------------------------------------------------------
AUTH_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Generative AI (Gemini REST API)
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Chronos, quotas, OpenRouter, OpenAI, Google CSE
# -----------------------------------------------------------------------------
# CHRONOS_ENABLED=false
# QUOTA_DAILY_TOKEN_LIMIT=500000
# QUOTA_DAILY_CHAT_LIMIT=120
