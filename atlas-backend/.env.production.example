# =============================================================================
# Obsidian Atlas — VPS production backend config
# Copy to `.env` on the VPS and fill in all <PLACEHOLDER> values.
# =============================================================================

PORT=3001
HOST=0.0.0.0
SQLITE_PATH=./data/atlas.db

# --- Required thresholds ---
MEMORY_CONFIDENCE_THRESHOLD=0.72
DATASET_SCORE_THRESHOLD=0.80
EVAL_GAP_THRESHOLD=0.42
DATASET_MIN_AXIS_SCORE=9
EVOLUTION_LLM_TIMEOUT_MS=120000

# --- Force cloud routing (no local Ollama on VPS) ---
DISABLE_LOCAL_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- GROQ (primary cloud inference — Llama 3.3 70B) ---
GROQ_API_KEY=<YOUR_GROQ_API_KEY>
CONSENSUS_GROQ_ANALYST_MODEL=llama-3.3-70b-versatile
CONSENSUS_GROQ_ALT_MODEL=mixtral-8x7b-32768
CONSENSUS_GROQ_JUDGE_MODEL=llama-3.3-70b-versatile

# --- GEMINI (consensus judge + dual-lane) ---
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>
CONSENSUS_GEMINI_MODEL=gemini-1.5-pro

# --- OAuth (Google) ---
# Redirect URI: https://obsidianatlastech.com/auth/google/callback
NEXTAUTH_URL=https://obsidianatlastech.com
AUTH_URL=https://obsidianatlastech.com
APP_URL=https://obsidianatlastech.com
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>
NEXTAUTH_SECRET=<GENERATE_WITH: openssl rand -base64 32>

# --- CORS ---
CORS_ORIGINS=https://obsidianatlastech.com
