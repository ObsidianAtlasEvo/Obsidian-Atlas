# Vite production build — loaded by `vite build` (no secrets here; use atlas-backend/.env for API keys).
# Reverse proxy must route /api → backend (strip /api) and /auth → backend; SPA serves dist/ for all other paths.
# Google OAuth redirect URI: https://obsidianatlastech.com/auth/google/callback

VITE_ATLAS_SAME_ORIGIN=true

APP_URL=https://obsidianatlastech.com
NEXTAUTH_URL=https://obsidianatlastech.com
AUTH_URL=https://obsidianatlastech.com

# Same-origin Ollama via proxy (optional): map /ollama → http://127.0.0.1:11434 on the edge, like vite dev.
# OLLAMA_CHAT_URL=https://obsidianatlastech.com/ollama/api/chat
