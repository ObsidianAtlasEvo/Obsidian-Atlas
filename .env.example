# =============================================================================
# Obsidian Atlas — Vite (root). Copy to `.env` or `.env.local`.
# Production build: `.env.production` is loaded by `vite build` (tracked; no secrets).
# Run: `npm run ci:build` or `npm ci && npm run build`
# Backend API keys live in `atlas-backend/.env` (loaded by the Node server).
# =============================================================================

# Browser Ollama default: Vite proxies /ollama → http://localhost:11434
# Only set if Ollama is on another host:
# OLLAMA_CHAT_URL=http://127.0.0.1:11434/api/chat

# Should match `ollama list` and align with atlas-backend OLLAMA_CHAT_MODEL when possible
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Large local models may need a high timeout (ms)
OLLAMA_REQUEST_TIMEOUT_MS=1200000

# Dev proxy target for `/api` and `/auth` (Fastify)
VITE_ATLAS_PROXY_TARGET=http://127.0.0.1:3001

# Required for governance console and AI commands in production.
# In dev mode (import.meta.env.DEV), the Vite proxy handles routing.
# In production, this MUST be set or VITE_ATLAS_SAME_ORIGIN=true must be used,
# otherwise atlasHttpEnabled() returns false and governance commands skip the backend.
# VITE_ATLAS_API_URL=https://your-backend-url.com
VITE_ATLAS_API_URL=http://127.0.0.1:3001

# Optional: set to true if frontend and backend are on the same origin
# (e.g., behind nginx that routes /api to the backend). When true, relative
# /api paths are used without needing VITE_ATLAS_API_URL.
VITE_ATLAS_SAME_ORIGIN=false

# VITE_ATLAS_AUTH_DISABLED=true
# VITE_ATLAS_INQUIRY_TIMEOUT_MS=300000

# --- Local dev (default after copy) ---
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# --- Production (Cloudflare Tunnel; Google redirect: https://obsidianatlastech.com/auth/google/callback) ---
# APP_URL=https://obsidianatlastech.com
# NEXTAUTH_URL=https://obsidianatlastech.com
# AUTH_URL=https://obsidianatlastech.com
# VITE_ATLAS_SAME_ORIGIN=true
