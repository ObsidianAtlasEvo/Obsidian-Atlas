# Obsidian Atlas — same-origin production (HTTPS automatic with Caddy).
# Adjust root path and domain. Backend: Fastify on 127.0.0.1:3001 (full app: atlas-backend/src/index.ts).
#
# DNS: point both apex and www to this host (A/AAAA or ALIAS).
# Caddy issues one certificate covering both names (SANs).
#
#   sudo caddy run --config /path/to/obsidian-atlas/deploy/Caddyfile
#
# Routes mirror vite.config.ts dev proxy:
#   /api/*  → backend with /api stripped → /v1/... on Fastify
#   /auth/* → backend unchanged
#   /ollama/* → local Ollama (optional; strip /ollama) — remove block if unused

obsidianatlastech.com, www.obsidianatlastech.com {
	root * /var/www/obsidian-atlas-src/dist
	encode gzip zstd

	# ── Security headers (all responses) ─────────────────────────────
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.openai.com https://api.groq.com https://api.anthropic.com https://generativelanguage.googleapis.com https://accounts.google.com https://js.stripe.com; frame-src https://js.stripe.com; object-src 'none'; base-uri 'self'"
	}

	# Direct /v1/* → backend (no prefix stripping needed — backend routes start with /v1/)
	handle /v1/* {
		reverse_proxy 127.0.0.1:3001 {
			header_up -X-Atlas-Verified-Email
			flush_interval -1
		}
	}

	# Strip /api prefix (same as Vite: /api/v1/foo → upstream /v1/foo)
	handle_path /api/* {
		reverse_proxy 127.0.0.1:3001 {
			# Strip spoofable identity header before it reaches the backend
			header_up -X-Atlas-Verified-Email
			flush_interval -1
		}
	}

	# AUDIT FIX: P2-10 — strip spoofable identity header on /auth* path
	handle /auth* {
		reverse_proxy 127.0.0.1:3001 {
			header_up -X-Atlas-Verified-Email
		}
	}

	# Optional: same-origin Ollama for browser (matches default OLLAMA_CHAT_URL /ollama/api/chat)
	handle_path /ollama/* {
		reverse_proxy 127.0.0.1:11434
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
